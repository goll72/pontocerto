{
  "compilerOptions": {
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "target": "esnext",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,

    "strict": true,
    "types": [
      "vite-plugin-solid-svg/types",
      "vite/client"
    ],

    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ]
  }
}
