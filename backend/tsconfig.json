{
    "compilerOptions": {
        "target": "esnext",
        "baseUrl": "./src",

        "allowSyntheticDefaultImports": true,
        "allowImportingTsExtensions": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "module": "nodenext",
        "moduleResolution": "nodenext",

        "strict": true,
        "types": ["node"]
    }
}
