{
  "compilerOptions": {
    "target": "esnext",
    "baseUrl": "./src",

    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,

    "strict": true,
    "types": [
      "node"
    ]
  }
}
