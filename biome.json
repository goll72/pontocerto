{
    "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
    "files": {
        "ignoreUnknown": false
    },
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "style": {
                "noNonNullAssertion": "off",
                "useImportType": {
                    "level": "on",
                    "options": {
                        "style": "separatedType"
                    }
                }
            }
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double"
        }
    },
    "json": {
        "formatter": {
            "trailingCommas": "none"
        }
    },
    "assist": {
        "enabled": true,
        "actions": {
            "source": {
                "organizeImports": {
                    "level": "on",
                    "options": {
                        "groups": [
                            [
                                "vite",
                                "vite/**",
                                "solid-js",
                                "solid-js/**",
                                "solid-devtools"
                            ],
                            ":BLANK_LINE:",
                            ["solid-bootstrap", "solid-bootstrap/**"],
                            ":BLANK_LINE:",
                            ["**/*.css", "**/*.scss"],
                            ":BLANK_LINE:",
                            ["**"]
                        ]
                    }
                }
            }
        }
    }
}
